{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "enabledManagers": ["custom.regex"],
  "schedule": ["after 3am and before 5am"],
  "timezone": "UTC",
  "automerge": false,
  "separateMajorMinor": true,
  "labels": ["dependencies"],
  "postUpgradeTasks": {
    "commands": [
      "bash .github/scripts/post_upgrade.sh {{{packageFile}}} {{{newVersion}}}"
    ],
    "fileFilters": [
      "charts/*/Chart.yaml",
      "charts/*/README.md",
      "charts/*/RELEASENOTES.md"
    ],
    "executionMode": "update"
  },
  "packageRules": [
    {
      "matchDepNames": ["ghost", "gitea/gitea", "graylog/graylog", "rabbitmq", "redis", "valkey/valkey"],
      "allowedVersions": "/^\\d+\\.\\d+\\.\\d+$/"
    },
    {
      "matchDepNames": ["mongo"],
      "allowedVersions": "/^(7\\.0\\.\\d+|8\\.0\\.\\d+|8\\.3\\.\\d+)$/"
    },
    {
      "matchDepNames": ["mysql"],
      "allowedVersions": "/^(8\\.4\\.\\d+|9\\.7\\.\\d+)$/"
    },
    {
      "matchDepNames": ["mariadb"],
      "allowedVersions": "/^(10\\.11\\.\\d+|11\\.4\\.\\d+|11\\.8\\.\\d+|12\\.3\\.\\d+)$/"
    },
    {
      "matchDepNames": ["quay.io/coreos/etcd", "umputun/remark42"],
      "allowedVersions": "/^v\\d+\\.\\d+\\.\\d+$/"
    },
    {
      "matchDepNames": ["nextcloud"],
      "allowedVersions": "/^\\d+\\.\\d+\\.\\d+-apache$/"
    },
    {
      "matchDepNames": ["wordpress"],
      "allowedVersions": "/^\\d+\\.\\d+\\.\\d+-apache$/"
    },
    {
      "matchDepNames": ["postgres"],
      "allowedVersions": "/^\\d+\\.\\d+$/"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^charts/etcd/Chart\\.yaml$/"
      ],
      "matchStrings": ["appVersion: \"?(?<currentValue>[^\"\\n]+)\"?"],
      "depNameTemplate": "quay.io/coreos/etcd",
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^charts/ghost/Chart\\.yaml$/"
      ],
      "matchStrings": ["appVersion: \"?(?<currentValue>[^\"\\n]+)\"?"],
      "depNameTemplate": "ghost",
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^charts/gitea/Chart\\.yaml$/"
      ],
      "matchStrings": ["appVersion: \"?(?<currentValue>[^\"\\n]+)\"?"],
      "depNameTemplate": "gitea/gitea",
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^charts/graylog/Chart\\.yaml$/"
      ],
      "matchStrings": ["appVersion: \"?(?<currentValue>[^\"\\n]+)\"?"],
      "depNameTemplate": "graylog/graylog",
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^charts/mariadb/Chart\\.yaml$/"
      ],
      "matchStrings": ["appVersion: \"?(?<currentValue>[^\"\\n]+)\"?"],
      "depNameTemplate": "mariadb",
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^charts/mongodb/Chart\\.yaml$/"
      ],
      "matchStrings": ["appVersion: \"?(?<currentValue>[^\"\\n]+)\"?"],
      "depNameTemplate": "mongo",
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^charts/mysql/Chart\\.yaml$/"
      ],
      "matchStrings": ["appVersion: \"?(?<currentValue>[^\"\\n]+)\"?"],
      "depNameTemplate": "mysql",
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^charts/nextcloud/Chart\\.yaml$/"
      ],
      "matchStrings": ["appVersion: \"?(?<currentValue>[^\"\\n]+)\"?"],
      "depNameTemplate": "nextcloud",
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^charts/postgres/Chart\\.yaml$/"
      ],
      "matchStrings": ["appVersion: \"?(?<currentValue>[^\"\\n]+)\"?"],
      "depNameTemplate": "postgres",
      "datasourceTemplate": "docker",
      "versioningTemplate": "loose"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^charts/rabbitmq/Chart\\.yaml$/"
      ],
      "matchStrings": ["appVersion: \"?(?<currentValue>[^\"\\n]+)\"?"],
      "depNameTemplate": "rabbitmq",
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^charts/redis/Chart\\.yaml$/"
      ],
      "matchStrings": ["appVersion: \"?(?<currentValue>[^\"\\n]+)\"?"],
      "depNameTemplate": "redis",
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^charts/remark42/Chart\\.yaml$/"
      ],
      "matchStrings": ["appVersion: \"?(?<currentValue>[^\"\\n]+)\"?"],
      "depNameTemplate": "umputun/remark42",
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^charts/valkey/Chart\\.yaml$/"
      ],
      "matchStrings": ["appVersion: \"?(?<currentValue>[^\"\\n]+)\"?"],
      "depNameTemplate": "valkey/valkey",
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^charts/wordpress/Chart\\.yaml$/"
      ],
      "matchStrings": ["appVersion: \"?(?<currentValue>[^\"\\n]+)\"?"],
      "depNameTemplate": "wordpress",
      "datasourceTemplate": "docker"
    }
  ]
}
